var backgroundColor = gfx.color(0, 0, 0)
var redColor = gfx.color(255, 0, 0)

gfx.init('Test', 800, 600)

var dieSound = gfx.load_sound('assets/die.wav')

while (1) {
    gfx.begin()
    gfx.clear(backgroundColor)
    
    if(gfx.key_pressed(32)) {
        gfx.play_sound(dieSound, 1.0, 0)
        print('Played sound!')
    }

    gfx.draw_rect(100, 100, 200, 150, redColor)
    gfx.draw_rect(100, 100, 400, 350, redColor, false)

    gfx.end()
    gfx.update()
}